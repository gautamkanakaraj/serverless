# ==========================================
# ⚡ Mini-Lambda Environment Configuration Template
# Copy this file to '.env' and fill in your actual values.
# ==========================================

# 1. Master Database Connection String
# Get yours from neon.tech. Example: postgresql://username:password@ep-host.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
NEON_DB_URL="postgresql://username:password@host.neon.tech/neondb?sslmode=require"

# 2. Google OAuth 2.0 Credentials
# Create these in the Google Cloud Console (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URL="http://localhost:8080/api/auth/callback"

# 3. Session JWT Configuration
# Generate a secure random secret key for signing session tokens
JWT_SECRET="generate-a-secure-random-secret-key"

# 4. App Environment Settings
# Set to 'production' to enforce secure HTTP-only cookies over HTTPS
APP_ENV="development"

# 5. Neon Project Integration Settings (Optional: For database auto-provisioning)
# Create a Neon API key under your Account Settings -> API Keys
NEON_API_KEY="your-neon-api-key"
NEON_PROJECT_ID="your-neon-project-id"

# 6. Database Encryption Key
# Must be exactly 32 bytes/characters long for AES-GCM encryption
DB_ENCRYPTION_KEY="your-32-character-encryption-key"
